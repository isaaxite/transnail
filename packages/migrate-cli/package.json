{
  "name": "@transnail/migrate-cli",
  "version": "1.0.0",
  "description": "Interactively migrate Markdown files and referenced assets between directories",
  "main": "./dist/index.cjs",
  "bin": {
    "migrate-cli": "dist/index.cjs",
    "@transnail/migrate-cli": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "ava",
    "test:coverage": "c8 ava",
    "test:md": "mkdir -p reports && ava --tap | tap-json | node ./.github/scripts/generate-report.js --title \"${npm_config_title:-AVA Test Results}\" > reports/ava-test.md",
    "test:report": "rimraf reports && npm run test:coverage && npm run test:md",
    "clean": "rimraf dist",
    "build:dev": "NODE_ENV=development npm run clean && rollup -c",
    "build:prod": "NODE_ENV=production npm run clean && rollup -c",
    "dev": "nodemon --watch index.ts --watch src -e ts --exec \"npm run build:dev\"",
    "check-publish": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:latest": "npm publish --tag latest --access public"
  },
  "ava": {
    "files": [
      "tests/**/*.mjs"
    ],
    "nodeArguments": [
      "--experimental-vm-modules"
    ]
  },
  "c8": {
    "reports-dir": "reports/coverage",
    "reporter": [
      "html",
      "lcov"
    ],
    "exclude": [
      "tests/**",
      "node_modules/**"
    ],
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 75
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaxite/transnail.git"
  },
  "bugs": {
    "url": "https://github.com/isaaxite/transnail/issues"
  },
  "keywords": [
    "markdown",
    "migrate",
    "assets",
    "cli",
    "interactive",
    "file-transfer"
  ],
  "author": {
    "name": "isaaxite",
    "url": "https://github.com/isaaxite"
  },
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/isaaxite/transnail#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@transnail/migrate": "workspace:*",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@types/signale": "^1.4.7",
    "ava": "^7.0.0",
    "c8": "^11.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "tap-json": "^1.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "minimist": "^1.2.8",
    "path-treeify": "^1.4.1",
    "prompts": "^2.4.2",
    "signale": "^1.4.0"
  }
}