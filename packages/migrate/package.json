{
  "name": "@transnail/migrate",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.cjs",
    "dist/index.mjs",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "test": "ava",
    "test:coverage": "c8 ava",
    "test:md": "mkdir -p reports && ava --tap | tap-json | node ./.github/scripts/generate-report.js --title \"${npm_config_title:-AVA Test Results}\" > reports/ava-test.md",
    "test:report": "rimraf reports && npm run test:coverage && npm run test:md",
    "clean": "rimraf dist",
    "build:dev": "NODE_ENV=development npm run clean && rollup -c",
    "build:prod": "NODE_ENV=production npm run clean && rollup -c",
    "dev": "nodemon --watch index.ts --watch src -e ts --exec \"npm run build:dev\"",
    "check-publish": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:latest": "npm publish --tag latest --access public"
  },
  "ava": {
    "files": [
      "tests/**/*.mjs"
    ],
    "nodeArguments": [
      "--experimental-vm-modules"
    ]
  },
  "c8": {
    "reports-dir": "reports/coverage",
    "reporter": [
      "html",
      "lcov"
    ],
    "exclude": [
      "tests/**",
      "node_modules/**"
    ],
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 75
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaxite/transnail.git"
  },
  "bugs": {
    "url": "https://github.com/isaaxite/transnail/issues"
  },
  "keywords": [],
  "author": {
    "name": "isaaxite",
    "url": "https://github.com/isaaxite"
  },
  "license": "ISC",
  "homepage": "https://github.com/isaaxite/transnail#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "devDependencies": {
    "@isaaxite/nodelib-scaffold": "^1.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "ava": "^7.0.0",
    "c8": "^11.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "tap-json": "^1.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "link-harvester": "^2.0.0",
    "path-treeify": "^1.4.1"
  }
}
