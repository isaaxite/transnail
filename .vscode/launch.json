{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch @transnail/migrate",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeExecutable": "tsx",
      "program": "${workspaceFolder}/packages/migrate/dev/index.ts",
      "console": "integratedTerminal",
      "outFiles": [
        "${workspaceFolder}/**/*.ts"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch @transnail/migrate-cli",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeExecutable": "tsx",
      "program": "${workspaceFolder}/packages/migrate-cli/dev/index.ts",
      "console": "integratedTerminal",
      "outFiles": [
        "${workspaceFolder}/**/*.ts"
      ]
    },
  ]
}